{
  "name": "@dllm/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --parallel dev:css dev:serve",
    "dev:css": "./node_modules/.bin/tailwindcss -i ./src/index.css -o ./dist/assets/app.css --watch=always",
    "dev:serve": "bun run dev-server.ts",
    "build": "tsc -b && bun run build:css && bun run build:bundle",
    "build:css": "./node_modules/.bin/tailwindcss -i ./src/index.css -o ./dist/assets/app.css --minify",
    "build:bundle": "bun build --target browser --outdir ./dist ./index.html",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.3"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
