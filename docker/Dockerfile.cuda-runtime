ARG RUST_VERSION=1.96
ARG CUDA_VERSION=12.9.1
ARG CUDA_ARCHITECTURES=61
ARG UBUNTU_VERSION=24.04

FROM nvidia/cuda:${CUDA_VERSION}-devel-ubuntu${UBUNTU_VERSION} AS builder
ARG RUST_VERSION
ARG CUDA_ARCHITECTURES
WORKDIR /src
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake build-essential libclang-dev curl ca-certificates pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --profile minimal --default-toolchain "${RUST_VERSION}"
ENV PATH=/root/.cargo/bin:${PATH}
ENV RUSTUP_TOOLCHAIN=${RUST_VERSION}
ENV CMAKE_CUDA_ARCHITECTURES=${CUDA_ARCHITECTURES}
COPY . .
RUN cargo build --release --locked --bin dllm-llama-server \
    --features dllm-llama-server/cuda \
    && strip target/release/dllm-llama-server

FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu${UBUNTU_VERSION}
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libgcc-s1 libgomp1 libstdc++6 libssl3 zlib1g libbrotli1 libzstd1 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /src/target/release/dllm-llama-server /usr/local/bin/dllm-llama-server
