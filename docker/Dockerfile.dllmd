ARG RUST_VERSION=1.96
ARG UBUNTU_VERSION=24.04
ARG CUDA_RUNTIME_IMAGE=ghcr.io/acidtib/dllm:cuda-runtime-sm61-v1

FROM oven/bun:1 AS web-builder
WORKDIR /src
COPY package.json bun.lock ./
COPY apps/web/package.json apps/web/package.json
RUN bun install --frozen-lockfile
COPY apps/web apps/web
RUN bun run --cwd apps/web build

FROM rust:${RUST_VERSION}-bookworm AS app-builder
ARG RUST_VERSION
ENV RUSTUP_TOOLCHAIN=${RUST_VERSION}
WORKDIR /src
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake build-essential libclang-dev \
    && rm -rf /var/lib/apt/lists/*
COPY . .
COPY --from=web-builder /src/apps/web/dist apps/web/dist
RUN cargo build --release --locked --bin dllmd --bin dllm \
    && strip target/release/dllmd target/release/dllm

FROM rust:${RUST_VERSION}-bookworm AS llama-cpu-builder
ARG RUST_VERSION
ENV RUSTUP_TOOLCHAIN=${RUST_VERSION}
WORKDIR /src
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake build-essential libclang-dev \
    && rm -rf /var/lib/apt/lists/*
COPY . .
RUN cargo build --release --locked --bin dllm-llama-server \
    && strip target/release/dllm-llama-server

FROM ubuntu:${UBUNTU_VERSION} AS llama-vulkan-builder
ARG RUST_VERSION
WORKDIR /src
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake build-essential libclang-dev curl ca-certificates pkg-config libssl-dev \
    libvulkan-dev glslc spirv-headers spirv-tools \
    && rm -rf /var/lib/apt/lists/*
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --profile minimal --default-toolchain "${RUST_VERSION}"
ENV PATH=/root/.cargo/bin:${PATH}
ENV RUSTUP_TOOLCHAIN=${RUST_VERSION}
COPY . .
RUN cargo build --release --locked --bin dllm-llama-server \
    --features dllm-llama-server/vulkan \
    && strip target/release/dllm-llama-server

FROM debian:bookworm-slim AS runtime-cpu
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libgcc-s1 libgomp1 libstdc++6 libssl3 zlib1g libbrotli1 libzstd1 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=app-builder /src/target/release/dllmd /usr/local/bin/dllmd
COPY --from=app-builder /src/target/release/dllm /usr/local/bin/dllm
COPY --from=llama-cpu-builder /src/target/release/dllm-llama-server /usr/local/bin/dllm-llama-server
ENV DLLMD_STATE=/var/lib/dllm/state.json
ENV DLLMD_AUTHORITY_KEY=/var/lib/dllm/authority.key
ENV DLLMD_NODE_KEY=/var/lib/dllm/node.key
ENV DLLMD_P2P_KEY=/var/lib/dllm/transport.key
# Remote management requires TLS credentials and API tokens.
ENV DLLMD_BIND=127.0.0.1:7337
RUN mkdir -p /var/lib/dllm
VOLUME /var/lib/dllm
EXPOSE 7337 7444
ENTRYPOINT ["dllmd"]

FROM ${CUDA_RUNTIME_IMAGE} AS runtime-cuda
COPY --from=app-builder /src/target/release/dllmd /usr/local/bin/dllmd
COPY --from=app-builder /src/target/release/dllm /usr/local/bin/dllm
ENV DLLMD_STATE=/var/lib/dllm/state.json
ENV DLLMD_AUTHORITY_KEY=/var/lib/dllm/authority.key
ENV DLLMD_NODE_KEY=/var/lib/dllm/node.key
ENV DLLMD_P2P_KEY=/var/lib/dllm/transport.key
ENV DLLMD_BIND=127.0.0.1:7337
RUN mkdir -p /var/lib/dllm
VOLUME /var/lib/dllm
EXPOSE 7337 7444
ENTRYPOINT ["dllmd"]

FROM ubuntu:${UBUNTU_VERSION} AS runtime-vulkan
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libgcc-s1 libgomp1 libstdc++6 libssl3 zlib1g libbrotli1 libzstd1 \
    libvulkan1 mesa-vulkan-drivers \
    && rm -rf /var/lib/apt/lists/*
COPY --from=app-builder /src/target/release/dllmd /usr/local/bin/dllmd
COPY --from=app-builder /src/target/release/dllm /usr/local/bin/dllm
COPY --from=llama-vulkan-builder /src/target/release/dllm-llama-server /usr/local/bin/dllm-llama-server
ENV DLLMD_STATE=/var/lib/dllm/state.json
ENV DLLMD_AUTHORITY_KEY=/var/lib/dllm/authority.key
ENV DLLMD_NODE_KEY=/var/lib/dllm/node.key
ENV DLLMD_P2P_KEY=/var/lib/dllm/transport.key
ENV DLLMD_BIND=127.0.0.1:7337
RUN mkdir -p /var/lib/dllm
VOLUME /var/lib/dllm
EXPOSE 7337 7444
ENTRYPOINT ["dllmd"]
