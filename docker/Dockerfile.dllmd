# Stage 1: build dllmd
FROM rust:1.96-bookworm AS builder
WORKDIR /src
COPY . .
RUN cargo build --release --bin dllmd --bin dllm

# Stage 2: minimal runtime
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libgcc-s1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/dllmd /usr/local/bin/dllmd
COPY --from=builder /src/target/release/dllm /usr/local/bin/dllm

# Default state and key paths (override with volumes or env vars)
ENV DLLMD_STATE=/var/lib/dllm/state.json
ENV DLLMD_OWNER_KEY=/var/lib/dllm/owner.key
ENV DLLMD_NODE_KEY=/var/lib/dllm/node.key
# Bind to loopback by default. For remote access, override to 0.0.0.0:7337
# and set DLLMD_TLS_CERT, DLLMD_TLS_KEY, DLLMD_MANAGEMENT_TOKEN, and DLLMD_API_KEY.
ENV DLLMD_BIND=127.0.0.1:7337

RUN mkdir -p /var/lib/dllm
VOLUME /var/lib/dllm

EXPOSE 7337 7444
ENTRYPOINT ["dllmd"]
